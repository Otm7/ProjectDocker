#!/usr/bin/env php
<?php

// Minimal placeholder artisan script for TP purposes.
// It supports the commands used in init-laravel-3iw.sh.

$argv = $_SERVER['argv'];
array_shift($argv);
$cmd = implode(' ', $argv);

if (strpos($cmd, 'key:generate') === 0) {
    // create a .env key if missing
    $env = __DIR__ . '/.env';
    $contents = file_exists($env) ? file_get_contents($env) : '';
    if (!strpos($contents, 'APP_KEY=')) {
        $contents .= "\nAPP_KEY=base64:" . base64_encode(random_bytes(32)) . "\n";
        file_put_contents($env, $contents);
        echo "APP_KEY generated\n";
    } else {
        echo "APP_KEY already set\n";
    }
    exit(0);
}

if (strpos($cmd, 'migrate:fresh') === 0) {
    echo "Pretend migrating fresh to MySQL (not implemented).\n";
    exit(0);
}

if (strpos($cmd, 'migrate') === 0) {
    echo "Pretend running migrations (not implemented).\n";
    exit(0);
}

// default
echo "Artisan command not implemented: $cmd\n";
exit(0);
